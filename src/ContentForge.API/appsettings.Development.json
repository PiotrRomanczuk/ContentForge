{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "ContentForge": "Debug",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=contentforge;Username=admin;Password=admin"
  },
  "Auth": {
    "ApiKey": "CHANGE-ME-generate-a-strong-key",
    "JwtSecret": "CHANGE-ME-at-least-32-characters-long-secret-key-here",
    "Issuer": "ContentForge",
    "Audience": "ContentForge-API",
    "TokenExpirationHours": 24
  },
  "AllowedHosts": "*"
}
